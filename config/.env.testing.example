# =============================================================================
# Testing Environment Configuration
# Copy to your server as .env.testing (e.g. /secure/todolist/env/.env.testing)
# Replace placeholder values with real credentials. Do NOT commit secrets.
# =============================================================================

# Application
APP_ENV=testing
ASPNETCORE_ENVIRONMENT=Testing

# Database (use Jenkins credentials or env vars - never hardcode in repo)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=app_testing_db
DB_USER=app_testing_user
DB_PASSWORD=change-me-testing

# Connection string - use host.docker.internal when MySQL runs on host (container uses --add-host)
ConnectionStrings__Default=Server=host.docker.internal;Port=3306;Database=app_testing_db;User=app_testing_user;Password=change-me-testing;

# Database migrations
Database__ApplyMigrationsOnStartup=true

# Banking - sandbox to avoid real transactions
BANK_API_URL=https://sandbox.bank-api.com
PAYMENTS_ENABLED=false
