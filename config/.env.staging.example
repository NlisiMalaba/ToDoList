# =============================================================================
# Staging Environment Configuration
# Copy to your server as .env.staging (e.g. /secure/todolist/env/.env.staging)
# Replace placeholder values with real credentials. Do NOT commit secrets.
# =============================================================================

# Application
APP_ENV=staging
ASPNETCORE_ENVIRONMENT=Staging

# Database (use Jenkins credentials or env vars - never hardcode in repo)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=app_staging_db
DB_USER=app_staging_user
DB_PASSWORD=change-me-staging

# Connection string (override for .NET - build from vars above or use full string)
ConnectionStrings__Default=Server=localhost;Port=3306;Database=app_staging_db;User=app_staging_user;Password=change-me-staging;

# Database migrations
Database__ApplyMigrationsOnStartup=true

# Banking - sandbox to avoid real transactions
BANK_API_URL=https://sandbox.bank-api.com
PAYMENTS_ENABLED=false
