# =============================================================================
# Production Environment Configuration
# Copy to your server as .env.production (e.g. /secure/todolist/env/.env.production)
# Replace placeholder values with real credentials. Do NOT commit secrets.
# =============================================================================

# Application
APP_ENV=production
ASPNETCORE_ENVIRONMENT=Production

# Database (use Jenkins credentials or env vars - never hardcode in repo)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=app_production_db
DB_USER=app_production_user
DB_PASSWORD=change-me-production

# Connection string - use host.docker.internal when MySQL runs on host (container uses --add-host)
ConnectionStrings__Default=Server=host.docker.internal;Port=3306;Database=app_production_db;User=app_production_user;Password=change-me-production;

# Database migrations
Database__ApplyMigrationsOnStartup=true

# Banking - LIVE endpoints
BANK_API_URL=https://api.bank.com
PAYMENTS_ENABLED=true
