# Copy to a secure path on the testing VM, e.g. /secure/todolist/testing.env
# Do not commit real secrets.

# API
TESTING_EDGE_PORT=8080

# MySQL
TESTING_DB_PORT=23306
TESTING_DB_NAME=todolist_testing
TESTING_DB_USER=todolist_testing_user
TESTING_DB_PASSWORD=change-me-testing
TESTING_DB_ROOT_PASSWORD=change-me-root-testing

# Edge auth (testing)
TESTING_BASIC_AUTH_USER=qa
# Generate with: caddy hash-password --plaintext "your-password"
TESTING_BASIC_AUTH_PASSWORD_HASH=$2a$14$REPLACE_WITH_HASH

