# Copy to a secure path on the staging VM, e.g. /secure/todolist/staging.env
# Do not commit real secrets.

# API
STAGING_EDGE_PORT=8080

# MySQL
STAGING_DB_PORT=13306
STAGING_DB_NAME=todolist_staging
STAGING_DB_USER=todolist_staging_user
STAGING_DB_PASSWORD=change-me-staging
STAGING_DB_ROOT_PASSWORD=change-me-root-staging

# Edge auth (staging)
STAGING_BASIC_AUTH_USER=dev
# Generate with: caddy hash-password --plaintext "your-password"
STAGING_BASIC_AUTH_PASSWORD_HASH=$2a$14$REPLACE_WITH_HASH
# Optional IP allowlist (space-separated CIDRs), e.g. "10.0.0.0/8 192.168.0.0/16"
STAGING_ALLOWED_CIDRS=

